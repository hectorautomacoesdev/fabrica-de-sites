# =============================================================================
#  Fabrica de Sites - variaveis de ambiente
# =============================================================================
#  IMPORTANTE: A FASE 1 (Agente Scout via OpenStreetMap) NAO PRECISA DE NENHUMA
#  chave abaixo. Tudo funciona de graca, sem cadastro. As chaves abaixo sao
#  para fases futuras (fontes de dados mais ricas, LLMs, prospeccao).
#
#  Para usar: copie este arquivo para ".env" e preencha o que precisar.
#    cp .env.example .env   (Linux/Mac)
#    Copy-Item .env.example .env   (PowerShell)
# =============================================================================

# --- Fontes de dados alternativas (opcionais, fase 2+) ---------------------
# Serper.dev: 2.500 buscas/mes gratis - dados do Google Maps.  https://serper.dev
SERPER_API_KEY=

# Google Places API: ~US$200 de credito gratis/mes.  https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# --- LLMs (opcionais, para camada de insights e demais agentes) ------------
# Google Gemini: free tier generoso.  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude: usado na geracao de sites (Agente Criador), fase 4.
ANTHROPIC_API_KEY=

# --- Configuracao opcional de execucao -------------------------------------
# Sobrescreve a cidade-alvo padrao (default: Guaruja)
# CIDADE_ALVO=Guaruja
